{
  "name": "atlas-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Atlas AI — Private, offline AI assistant",
  "main": "dist/electron/main.js",
  "scripts": {
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "build:web": "cd atlas-web && npm run build",
    "compile": "tsc",
    "build": "npm run build:web && npm run compile",
    "start": "electron .",
    "dev": "npm run build && electron .",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@fastify/cors": "^10.1.0",
    "@fastify/static": "^8.3.0",
    "better-sqlite3": "^11.0.0",
    "fastify": "^5.8.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-rebuild": "^3.2.9",
    "typescript": "^5.5.0"
  },
  "build": {
    "appId": "com.atlas-ai.desktop",
    "productName": "Atlas AI",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "atlas-web/out/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/icons/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "resources/icons/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "resources/icons/icon.png"
    },
    "extraResources": [
      {
        "from": "resources/ollama",
        "to": "ollama"
      }
    ]
  }
}
